<%- include("includes/head") %>

<body>

  <h1 id="resume">My Resume</h1>

  <!-- Personal Info -->
  <h4>Name: <%= data.personalInfo.name %></h4>
  <h4>Email: <%= data.personalInfo.email %></h4>
  <h4>Phone: <%= data.personalInfo.phone %></h4>
  <h4>Location: <%= data.personalInfo.location %></h4>
  <h4>GitHub: <%= data.personalInfo.github %></h4>

  <hr>

  <!-- Objective -->
  <p><strong>Objective:</strong> <%= data.objective %></p>

  <!-- Education -->
  <h2>Education</h2>

  <% for(let edu of data.education){ %>
    <p>
      <%= edu.degree %> -
      <%= edu.college || edu.school %> -
      <%= edu.year %> -
      <%= edu.percentage %>
    </p>
  <% } %>

  <!-- Skills -->
  <h2>Technical Skills</h2>
  <ul>
    <% for(let skill of data.skills.technical){ %>
      <li><%= skill %></li>
    <% } %>
  </ul>

  <!-- Projects -->
  <h2>Projects</h2>
  <% for(let project of data.projects){ %>
    <h3><%= project.title %></h3>
    <p><%= project.description %></p>
  <% } %>

  <!-- Experience -->
  <% if(data.experience.length > 0){ %>
    <h2>Experience</h2>
    <% for(let exp of data.experience){ %>
      <p>
        <strong><%= exp.role %></strong> -
        <%= exp.company %> (<%= exp.duration %>)
      </p>
      <p><%= exp.description %></p>
    <% } %>
  <% } %>

  <!-- Certifications -->
  <h2>Certifications</h2>
  <% for(let cert of data.certifications){ %>
    <p><%= cert.name %> - <%= cert.platform %> (<%= cert.year %>)</p>
  <% } %>

  <!-- Hobbies -->
  <h2>Hobbies</h2>
  <ul>
    <% for(let hobby of data.hobbies){ %>
      <li><%= hobby %></li>
    <% } %>
  </ul>

  <!-- Languages -->
  <h2>Languages</h2>
  <ul>
    <% for(let lang of data.languages){ %>
      <li><%= lang %></li>
    <% } %>
  </ul>

</body>
</html>